# SPDX-License-Identifier: MPL-2.0-or-later
# OikosBot production environment template.
# Copy to /etc/oikosbot/.env (root:root, mode 0600) and fill in real values.
#
# NEVER commit a populated copy of this file. It contains secrets.

# -----------------------------------------------------------------------------
# Caddy / TLS
# -----------------------------------------------------------------------------

# Public domain pointed at this Hetzner box. Needs A/AAAA records configured
# before first `systemctl start caddy` so Let's Encrypt can complete the
# HTTP-01 challenge.
BOT_DOMAIN=bot.example.com

# Used by Caddy for the Let's Encrypt account. Renewal failure notifications
# go here. Use a real, monitored mailbox.
BOT_ADMIN_EMAIL=ops@example.com

# -----------------------------------------------------------------------------
# GitHub App credentials
# -----------------------------------------------------------------------------

# Numeric App ID from https://github.com/settings/apps/oikosbot
GITHUB_APP_ID=2538504

# Webhook secret. Generate with: openssl rand -hex 32
# Must match what's configured in the GitHub App settings page.
GITHUB_WEBHOOK_SECRET=

# Private key in PKCS#8 PEM (NOT the raw PKCS#1 GitHub gives you — convert with
# `openssl pkcs8 -topk8 -inform pem -in raw.pem -outform pem -nocrypt`).
# Either inline (newlines as \n) or via GITHUB_PRIVATE_KEY_FILE.
GITHUB_PRIVATE_KEY=
# GITHUB_PRIVATE_KEY_FILE=/etc/oikosbot/github-app.pkcs8.pem

# -----------------------------------------------------------------------------
# GitLab webhook (optional — leave blank if only GitHub is used)
# -----------------------------------------------------------------------------

GITLAB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Analyser
# -----------------------------------------------------------------------------

# Until the Haskell analyser (analyzers/code-haskell/) ships as a container,
# leave this pointing nowhere — the bot will post honest "analyser unavailable"
# comments + neutral check runs (see PR #32 fail-closed contract).
# When the analyser exists, point at its internal hostname, e.g.
# https://analyzer:8080
ANALYSIS_ENDPOINT=http://analyzer.unavailable.invalid

# -----------------------------------------------------------------------------
# Bot behaviour
# -----------------------------------------------------------------------------

# advisor | consultant | regulator. See bot-integration/README.md.
BOT_MODE=advisor

# DEV ONLY — never set this in production. If unset, the bot refuses to accept
# unsigned webhooks (Config.res fail-closed contract).
# OIKOS_ALLOW_UNVERIFIED_WEBHOOKS=true
