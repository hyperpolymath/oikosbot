# Private network shared by all OikosBot Quadlet containers.
# Install path: /etc/containers/systemd/oikos.network
# After install: systemctl daemon-reload && systemctl start oikos-network.service

[Network]
NetworkName=oikos
DisableDNS=false
Internal=false
# Bound to localhost so the host can reach the analyser via SSH tunnel for
# debugging, but the network itself is not externally routable.
Subnet=10.89.0.0/24
Gateway=10.89.0.1
