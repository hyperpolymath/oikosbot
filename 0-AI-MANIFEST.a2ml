#
# 0-AI-MANIFEST.a2ml — AI agent entry point for hyperpolymath/oikosbot.
# Read this first, then .claude/CLAUDE.md and .machine_readable/6a2/STATE.a2ml.
[ai-manifest]
version = "1.1"
repository = "oikosbot"
owner = "hyperpolymath"
project = "OikosBot — an ecological & economic code-analysis GitHub/GitLab App"

[entry-points]
primary = "README.adoc"
ai-instructions = ".claude/CLAUDE.md"
machine-readable = ".machine_readable/6a2/"
disambiguation = "DISAMBIGUATION.adoc"

[invariants]
license = "MPL-2.0"
machine-readable-location = ".machine_readable/6a2/*.a2ml (six core files); no loose state files in repo root or .machine_readable/ top level"
github-is-source-of-truth = true
not-the-dsl = "This repo is OikosBot, NOT the `oikos` economics DSL (hyperpolymath/oikos-economics-accounting-dsl) and NOT the `sustainabot` gitbot-fleet slot. See DISAMBIGUATION.adoc."
datastore = "Single store = VeriSimDB (octad of modal witnesses); runtime client deferred. See META.a2ml ADR-001."
